# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values
# =============================================================================

# App environment: development | beta | production
# Use NEXT_PUBLIC_APP_ENV=beta on the beta deployment and =production on the real live site.
NEXT_PUBLIC_APP_ENV=development

# Public frontend/site URL
# Beta: https://beta.telyx.ai
# Production: https://telyx.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-08CRCMG37C

# API Backend URL (REQUIRED)
# Local: http://localhost:3001
# Beta: https://beta-api.telyx.ai
# Production: https://api.telyx.ai
NEXT_PUBLIC_API_URL=http://localhost:3001

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth (for Google sign-in)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Internal-only WhatsApp manual fallback
NEXT_PUBLIC_WHATSAPP_MANUAL_FALLBACK=false

# WhatsApp live handoff workspace
# Keep false by default. Enable only on beta while testing the live takeover flow.
NEXT_PUBLIC_WHATSAPP_LIVE_HANDOFF_V2=false

# Optional company profile fields (About page)
NEXT_PUBLIC_COMPANY_CITY=
NEXT_PUBLIC_COMPANY_COUNTRY=
NEXT_PUBLIC_COMPANY_CONTACT_CHANNEL=info@telyx.ai
NEXT_PUBLIC_COMPANY_LEGAL_ADDRESS=

# Landing page widget
# Set a beta-specific embed key if you want the homepage widget active on beta.
NEXT_PUBLIC_LANDING_CHAT_EMBED_KEY=

# Red Alert operational panel
NEXT_PUBLIC_FEATURE_REDALERT_OPS_PANEL=false
