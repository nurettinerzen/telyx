# Copy shared values from .env.example, then apply the production-specific overrides below.

NODE_ENV=production
APP_ENV=production

FRONTEND_URL=https://telyx.ai
SITE_URL=https://telyx.ai
BACKEND_URL=https://api.telyx.ai
ALLOWED_ORIGINS=https://telyx.ai,https://api.telyx.ai
SESSION_COOKIE_DOMAIN=telyx.ai
ADMIN_MFA_MAX_AGE_MINUTES=15

# Keep live handoff disabled on production until beta verification is complete.
WHATSAPP_LIVE_HANDOFF_V2=false

# Stripe production values: use LIVE mode only.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID_TRY=price_xxx
STRIPE_PRO_PRICE_ID_TRY=price_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx
# Phone channel rollout
PHONE_OUTBOUND_V1_ENABLED=false
PHONE_OUTBOUND_V1_CANARY_BUSINESS_IDS=
PHONE_INBOUND_ENABLED=false
PHONE_INBOUND_CANARY_BUSINESS_IDS=
