# =============================================================================
# BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in the values
# =============================================================================

# Server Configuration
PORT=3001
NODE_ENV=development
# App environment: development | beta | production
# Keep NODE_ENV=production on hosted environments, and use APP_ENV to distinguish beta vs live.
APP_ENV=development
# Malware scan mode: required | best_effort
# If your runtime does not have ClamAV installed (e.g. many PaaS providers), use best_effort.
MALWARE_SCAN_MODE=best_effort

# URLs (REQUIRED)
# Local: http://localhost:3000
# Beta: https://beta.telyx.ai
# Production: https://telyx.ai
FRONTEND_URL=http://localhost:3000

# Public marketing/canonical site URL
# Beta: https://beta.telyx.ai
# Production: https://telyx.ai
SITE_URL=http://localhost:3000

# Backend URL (REQUIRED)
# Local: http://localhost:3001
# Beta: https://beta-api.telyx.ai
# Production: https://api.telyx.ai
BACKEND_URL=http://localhost:3001

# CORS Allowed Origins (comma-separated, REQUIRED)
# Local: http://localhost:3000,http://localhost:3001
# Beta: https://beta.telyx.ai,https://beta-api.telyx.ai
# Production: https://telyx.ai,https://api.telyx.ai
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Shared session cookie domain (optional)
# Leave empty on localhost.
# Beta / Production: telyx.ai
SESSION_COOKIE_DOMAIN=

# Database (REQUIRED)
DATABASE_URL=postgresql://user:password@localhost:5432/telyx_dev

# Authentication (REQUIRED)
JWT_SECRET=your-jwt-secret-here-min-32-characters
NEXTAUTH_SECRET=your-nextauth-secret-here
ADMIN_MFA_MAX_AGE_MINUTES=15

# Token Encryption (REQUIRED for OAuth/PII field-level encryption)
# Preferred: ENCRYPTION_MASTER_KEY
# Backward compatibility: ENCRYPTION_SECRET is also accepted
ENCRYPTION_MASTER_KEY=your-master-key-here-min-32-characters
# ENCRYPTION_SECRET=legacy-key-here
# KEY_PROVIDER options: env (current), kms, vault
KEY_PROVIDER=env

# =============================================================================
# THIRD-PARTY SERVICES
# =============================================================================

# 11Labs Conversational AI
ELEVENLABS_API_KEY=

# Primary LLM provider for chat/email orchestration: gemini | openai | auto
# Production recommendation: openai
LLM_PROVIDER=openai

# Google AI / Gemini (legacy/fallback provider)
# Preferred variable name:
GEMINI_API_KEY=
# Backward-compatible alias (supported, but prefer GEMINI_API_KEY):
# GOOGLE_AI_API_KEY=

# OpenAI (required when LLM_PROVIDER=openai; also used by specific phone/email helper flows)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# Stripe (for international payments)
# Beta should use Stripe test keys, test webhook secret, and test price IDs.
# Production should use Stripe live keys, live webhook secret, and live price IDs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe recurring plan prices
STRIPE_STARTER_PRICE_ID_TRY=
STRIPE_PRO_PRICE_ID_TRY=

# Optional non-TRY fallbacks
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# Written support pricing / quotas
TRIAL_WRITTEN_INTERACTIONS=50
STARTER_WRITTEN_INTERACTIONS=500
PRO_WRITTEN_INTERACTIONS=2000
WRITTEN_INTERACTION_PRICE_TRY=2.5

# Resend (for email)
RESEND_API_KEY=
SIGNUP_NOTIFICATION_EMAIL=
PUBLIC_CONTACT_OWNER_EMAIL=
LEAD_INGEST_SECRET=
LEAD_PREVIEW_OWNER_EMAIL=info@telyx.ai
LEAD_PREVIEW_ASSISTANT_NAME=Demo
LEAD_PREVIEW_FIRST_MESSAGE=Merhaba, ben Teliks demo asistanıyım. Nasılsınız? Bugün nasılsınız?

# Marketing analytics relay to Campaign Orchestrator
# Local: http://localhost:4100/api/analytics/events
CAMPAIGN_ORCHESTRATOR_ANALYTICS_URL=
CAMPAIGN_ORCHESTRATOR_ANALYTICS_SECRET=

# Phone channel rollout
PHONE_OUTBOUND_V1_ENABLED=false
PHONE_OUTBOUND_V1_CANARY_BUSINESS_IDS=
PHONE_INBOUND_ENABLED=false
PHONE_INBOUND_CANARY_BUSINESS_IDS=
EMAIL_FROM=Telyx.AI <notifications@telyx.ai>
SELF_SEND_FROM_EMAIL=Telyx.AI Notifications <notifications@telyx.ai>
LEAD_AUTO_RESPONSE_FROM_EMAIL=Nurettin Erzen <nurettin@telyx.ai>
LEAD_AUTO_RESPONSE_REPLY_TO=nurettin@telyx.ai
ELEVENLABS_DEMO_AGENT_ID=
ELEVENLABS_DEMO_PHONE_NUMBER_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Amazon SP-API OAuth
AMAZON_SP_API_APP_ID=
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_DEFAULT_MARKETPLACE_ID=A33AVAJ2PDY3EV
AMAZON_SP_API_SELLER_CENTRAL_URL=https://sellercentral.amazon.com.tr
AMAZON_SP_API_USE_DRAFT_AUTH=true
AMAZON_SP_API_USE_SANDBOX=false

# Meta / WhatsApp Embedded Signup
META_APP_ID=
META_APP_SECRET=
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=1592026702081670
META_GRAPH_API_VERSION=v22.0
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_MANUAL_FALLBACK_ENABLED=false
WHATSAPP_LIVE_HANDOFF_V2=false

# Meta Conversions API (server-side Pixel events for ad optimization & dedup)
# - META_PIXEL_ID: same Pixel ID used in frontend (NEXT_PUBLIC_META_PIXEL_ID)
# - META_CAPI_ACCESS_TOKEN: generated in Events Manager → Settings → Conversions API
# - META_TEST_EVENT_CODE: fill ONLY for staging/testing (e.g. TEST123). Leave empty in prod.
# CAPI reuses META_GRAPH_API_VERSION above (defaults to v18.0 if unset).
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# Shopify Integration
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Supabase (for file storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# NetGSM (for SMS/SIP)
NETGSM_USERNAME=
NETGSM_PASSWORD=


# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable experimental features
CHAT_RATE_LIMITING_ENABLED=false

# Phase 1: Unified trace write path
FEATURE_UNIFIED_RESPONSE_TRACE=false
# Optional allowlist (comma-separated business IDs). Empty = all businesses when flag=true
FEATURE_UNIFIED_RESPONSE_TRACE_CANARY_BUSINESS_IDS=

# Phase 1: Operational incident emitter
FEATURE_OPERATIONAL_INCIDENTS=false
# Optional allowlist (comma-separated business IDs). Empty = all businesses when flag=true
FEATURE_OPERATIONAL_INCIDENTS_CANARY_BUSINESS_IDS=

# Phase 1: Red Alert operational panel API gate
FEATURE_REDALERT_OPS_PANEL=false
# Optional allowlist (comma-separated business IDs). Empty = all businesses when flag=true
FEATURE_REDALERT_OPS_PANEL_CANARY_BUSINESS_IDS=

# Phase 2: Policy append mode
# allowed: legacy | monitor_only | off
FEATURE_POLICY_APPEND_MODE=legacy
# Optional allowlist (comma-separated business IDs). Empty = all businesses
FEATURE_POLICY_APPEND_CANARY_BUSINESS_IDS=
