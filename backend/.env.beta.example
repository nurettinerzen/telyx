# Copy shared values from .env.example, then apply the beta-specific overrides below.

NODE_ENV=production
APP_ENV=beta

FRONTEND_URL=https://beta.telyx.ai
SITE_URL=https://beta.telyx.ai
BACKEND_URL=https://beta-api.telyx.ai
ALLOWED_ORIGINS=https://beta.telyx.ai,https://beta-api.telyx.ai
SESSION_COOKIE_DOMAIN=telyx.ai
ADMIN_MFA_MAX_AGE_MINUTES=15

# Enable live WhatsApp takeover only in beta while the workflow is under test.
WHATSAPP_LIVE_HANDOFF_V2=true

# Stripe beta values: use TEST mode only.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID_TRY=price_xxx
STRIPE_PRO_PRICE_ID_TRY=price_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# Amazon SP-API beta values.
# Use the beta/draft authorization flow until the seller app is published.
AMAZON_SP_API_APP_ID=amzn1.sellerapps.app.xxxxxxxx
AMAZON_SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxx
AMAZON_SP_API_CLIENT_SECRET=xxxxxxxx
AMAZON_SP_API_DEFAULT_MARKETPLACE_ID=A33AVAJ2PDY3EV
AMAZON_SP_API_SELLER_CENTRAL_URL=https://sellercentral.amazon.com.tr
AMAZON_SP_API_USE_DRAFT_AUTH=true
AMAZON_SP_API_USE_SANDBOX=false

# Phone channel rollout
PHONE_OUTBOUND_V1_ENABLED=false
PHONE_OUTBOUND_V1_CANARY_BUSINESS_IDS=
PHONE_INBOUND_ENABLED=false
PHONE_INBOUND_CANARY_BUSINESS_IDS=
